# Core runtime
PROJECT_ROOT=/app
SQLITE_PATH=/app/memory/vito_local.db
CHROMA_PATH=/app/memory/chroma_db
DATABASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Primary LLM routing
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Auth / anti-bot / browser
ANTICAPTCHA_KEY=
AUTH_SESSION_TTL_SEC=10800
AUTH_PREFER_BROWSER_COOKIE=true
BROWSER_DEFAULT_ON_URL=true
BROWSER_SAFE_MODE_ENABLED=true
BROWSER_AUTOMATION_ENGINE=auto
BROWSER_PROXY_POOL=
BROWSER_PROXY_COOLDOWN_SEC=900
BROWSER_CHALLENGE_DETECT_ENABLED=true
BROWSER_CHALLENGE_BLOCK_MODE=true
PLATFORM_CIRCUIT_BREAKER_FAIL_THRESHOLD=3
PLATFORM_CIRCUIT_BREAKER_COOLDOWN_SEC=1800
PLATFORM_CIRCUIT_BREAKER_LONG_COOLDOWN_SEC=21600

# Owner / dialogue
NOTIFY_MODE=minimal
TELEGRAM_STRICT_COMMANDS=true
OWNER_TASK_STATE_PATH=/app/runtime/owner_task_state.json
CONVERSATION_HISTORY_PATH=/app/runtime/conversation_history.json
CONVERSATION_CONTEXT_TURNS=20

# Autonomy / safety
AUTONOMY_MAX_MODE=false
AUTONOMY_AUTO_LEARN_ON_FAILURE=true
AUTONOMY_AUTO_SELF_IMPROVE_ON_MISS=false
VITO_EVOLUTION_ENABLED=true
EVOLUTION_DISCOVERY_ENABLED=true
EVOLUTION_DISCOVERY_INTERVAL_TICKS=2016
EVOLUTION_DISCOVERY_QUERIES=python autonomous agents memory benchmark runtime;python browser automation resilience;python self-healing sandbox patch apply
EVOLUTION_OVERSEER_ENABLED=true
EVOLUTION_OVERSEER_INTERVAL_TICKS=72
EVOLUTION_OVERSEER_STUCK_TICKS=288
EVOLUTION_AUDIT_SECRET=
EVOLUTION_SANDBOX_ALLOWED_ENV=PATH,HOME,LANG,LC_ALL,PYTHONPATH,VIRTUAL_ENV,TZ
GUARDRAILS_BLOCK_ON_INJECTION=true
SELF_LEARNING_AUTO_PROMOTE=false

# Models / Gemini economy mode
LLM_ROUTER_MODE=prod
LLM_FORCE_GEMINI_FREE=false
LLM_FORCE_GEMINI_MODEL=gemini-2.5-flash
RESEARCH_ROUTER_MODE=test
GEMINI_ENABLE_GROUNDING_SEARCH=true
GEMINI_ENABLE_URL_CONTEXT=true
GEMINI_EMBEDDINGS_ENABLED=true
MEM0_ENABLED=false
MEM0_API_KEY=
MEM0_USER_ID=vito_owner
MEM0_COLLECTION=vito_runtime
LLM_RATE_LIMIT_GOOGLE_RPM=15
LLM_RATE_LIMIT_OPENAI_RPM=60
LLM_RATE_LIMIT_ANTHROPIC_RPM=60
LLM_RATE_LIMIT_PERPLEXITY_RPM=30
LLM_RATE_LIMIT_OPENROUTER_RPM=60
LLM_RATE_LIMIT_MAX_WAIT_SEC=60
MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_CONSOLIDATION_INTERVAL_TICKS=288
MEMORY_CONSOLIDATION_MIN_AGE_DAYS=5
MEMORY_CONSOLIDATION_LIMIT=25
CONTENT_AB_EXPERIMENTS_ENABLED=true

# Browser storage states
GUMROAD_STORAGE_STATE_FILE=/app/runtime/gumroad_storage_state.json
ETSY_STORAGE_STATE_FILE=/app/runtime/etsy_storage_state.json
KDP_STORAGE_STATE_FILE=/app/runtime/kdp_storage_state.json
TWITTER_STORAGE_STATE_FILE=/app/runtime/twitter_storage_state.json
REDDIT_STORAGE_STATE_FILE=/app/runtime/reddit_storage_state.json
THREADS_STORAGE_STATE_FILE=/app/runtime/threads_storage_state.json
PINTEREST_STORAGE_STATE_FILE=/app/runtime/pinterest_storage_state.json
PRINTFUL_STORAGE_STATE_FILE=/app/runtime/printful_storage_state.json
INSTAGRAM_STORAGE_STATE_FILE=/app/runtime/instagram_storage_state.json
INSTAGRAM_SESSION_FILE=/app/runtime/instagram_instagrapi_session.json
TIKTOK_STORAGE_STATE_FILE=/app/runtime/tiktok_storage_state.json
LINKEDIN_STORAGE_STATE_FILE=/app/runtime/linkedin_storage_state.json
SHOPIFY_STORAGE_STATE_FILE=/app/runtime/shopify_storage_state.json
SUBSTACK_STORAGE_STATE_FILE=/app/runtime/substack_storage_state.json
CREATIVE_FABRICA_STORAGE_STATE_FILE=/app/runtime/creative_fabrica_storage_state.json

