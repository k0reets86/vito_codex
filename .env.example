# Core runtime
PROJECT_ROOT=/app
SQLITE_PATH=/app/memory/vito_local.db
CHROMA_PATH=/app/memory/chroma_db
DATABASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Primary LLM routing
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Auth / anti-bot / browser
ANTICAPTCHA_KEY=
AUTH_SESSION_TTL_SEC=10800
AUTH_PREFER_BROWSER_COOKIE=true
BROWSER_DEFAULT_ON_URL=true
BROWSER_SAFE_MODE_ENABLED=true
BROWSER_CHALLENGE_DETECT_ENABLED=true
BROWSER_CHALLENGE_BLOCK_MODE=true

# Owner / dialogue
NOTIFY_MODE=minimal
TELEGRAM_STRICT_COMMANDS=true
OWNER_TASK_STATE_PATH=/app/runtime/owner_task_state.json
CONVERSATION_HISTORY_PATH=/app/runtime/conversation_history.json
CONVERSATION_CONTEXT_TURNS=20

# Autonomy / safety
AUTONOMY_MAX_MODE=false
AUTONOMY_AUTO_LEARN_ON_FAILURE=true
AUTONOMY_AUTO_SELF_IMPROVE_ON_MISS=false
GUARDRAILS_BLOCK_ON_INJECTION=false
SELF_LEARNING_AUTO_PROMOTE=false

# Models / Gemini economy mode
LLM_ROUTER_MODE=prod
LLM_FORCE_GEMINI_FREE=false
LLM_FORCE_GEMINI_MODEL=gemini-2.5-flash
RESEARCH_ROUTER_MODE=test
GEMINI_ENABLE_GROUNDING_SEARCH=true
GEMINI_ENABLE_URL_CONTEXT=true
GEMINI_EMBEDDINGS_ENABLED=true

# Browser storage states
GUMROAD_STORAGE_STATE_FILE=/app/runtime/gumroad_storage_state.json
ETSY_STORAGE_STATE_FILE=/app/runtime/etsy_storage_state.json
KDP_STORAGE_STATE_FILE=/app/runtime/kdp_storage_state.json
TWITTER_STORAGE_STATE_FILE=/app/runtime/twitter_storage_state.json
REDDIT_STORAGE_STATE_FILE=/app/runtime/reddit_storage_state.json
THREADS_STORAGE_STATE_FILE=/app/runtime/threads_storage_state.json
PINTEREST_STORAGE_STATE_FILE=/app/runtime/pinterest_storage_state.json
PRINTFUL_STORAGE_STATE_FILE=/app/runtime/printful_storage_state.json

# Commerce / social credentials (fill only what you use)
GUMROAD_EMAIL=
GUMROAD_PASSWORD=
GUMROAD_API_KEY=
GUMROAD_OAUTH_TOKEN=
ETSY_EMAIL=
ETSY_PASSWORD=
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=
ETSY_SHOP_ID=
ETSY_OAUTH_ACCESS_TOKEN=
ETSY_OAUTH_REFRESH_TOKEN=
KOFI_API_KEY=
KOFI_PAGE_ID=
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
KDP_EMAIL=
KDP_PASSWORD=
TWITTER_MODE=browser
TWITTER_BEARER_TOKEN=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
REDDIT_MODE=browser
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Media / assets
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
