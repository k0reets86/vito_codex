[Unit]
Description=VITO Autonomous Agent
After=network.target

[Service]
User=vito
WorkingDirectory=/home/vito/vito-agent
ExecStartPre=/bin/bash -c 'test -f /tmp/vito_agent.pid && kill $(cat /tmp/vito_agent.pid) 2>/dev/null; rm -f /tmp/vito_agent.pid; true'
ExecStart=/usr/bin/python3 -u main.py
Restart=always
RestartSec=30
KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=15
MemoryMax=4G
MemoryHigh=3G
TasksMax=100

[Install]
WantedBy=multi-user.target
